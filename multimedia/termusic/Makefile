OPENSSLLIB=	/usr/lib

PROGS=		termusic \
		termusic-server

PLIST_FILES=	${PROGS:S/^/bin\//}

do-install:
	# workaround for error: found a virtual manifest at `xx` instead of a package manifest
.for p in ${PROGS}
	${INSTALL_PROGRAM} \
		${WRKDIR}/target/release/${p} \
		${STAGEDIR}${PREFIX}/bin
.endfor

